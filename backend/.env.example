# idle-scribe backend configuration.
# Copy this file to `.env` (same folder) and fill in values. All keys use the
# IDLE_SCRIBE_ prefix. The backend reads this file at startup — restart uvicorn
# after changing it. `.env` is gitignored; never commit real keys.

# --- ElevenLabs (cloud engine) ---
# Get a key at https://elevenlabs.io (Profile → API Keys). Once set, "elevenlabs"
# appears in the engine picker automatically.
# IDLE_SCRIBE_ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx
# IDLE_SCRIBE_ELEVENLABS_MODEL=scribe_v1

# --- OpenAI (optional fallback engine) ---
# IDLE_SCRIBE_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# --- Local Whisper (defaults shown) ---
# IDLE_SCRIBE_WHISPER_MODEL=large-v3
# IDLE_SCRIBE_WHISPER_DEVICE=cuda          # or cpu
# IDLE_SCRIBE_WHISPER_COMPUTE_TYPE=float16 # or int8_float16 to save VRAM
# IDLE_SCRIBE_WHISPER_LANGUAGE=            # blank = autodetect; af / en to pin

# --- Diarization (defaults shown) ---
# IDLE_SCRIBE_ENABLE_DIARIZATION=true
# IDLE_SCRIBE_DIARIZATION_DEVICE=cpu       # cuda if you accept the VRAM/cuDNN tradeoff
# HF token is read from `huggingface-cli login`; override here if needed:
# IDLE_SCRIBE_HF_TOKEN=hf_xxxxxxxxxxxxxxxx

# --- Frontend origins allowed via CORS ---
# IDLE_SCRIBE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
